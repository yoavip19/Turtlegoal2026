<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Checkbox visible only for goal owner (user role) -->
        <CheckBox
            android:id="@+id/cb_roadmap_task_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#286B33"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_roadmap_task_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#4F4541"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_roadmap_task_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9E8880"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_roadmap_task_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#B0A09A"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Tip button visible only for tipper role -->
        <Button
            android:id="@+id/btn_roadmap_task_tip"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="💡 Tip"
            android:textSize="12sp"
            android:backgroundTint="#FFA726"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Tips/comments section for this task -->
    <LinearLayout
        android:id="@+id/ll_task_tips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="44dp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

</LinearLayout>
