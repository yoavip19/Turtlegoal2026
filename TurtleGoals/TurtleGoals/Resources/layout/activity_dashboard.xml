<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- ── Goals Banner ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:text="My Goals"
            android:textColor="#6D574F"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGoalsBanner"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginStart="-8dp"
            android:layout_marginEnd="-8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:contentDescription="Horizontal list of your goals"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvNoGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:text="No goals yet — create one below!"
            android:textColor="#9E8880"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hey there! 👋"
                    android:textColor="#6D574F"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Today"
                    android:textColor="#9E8880"
                    android:textSize="14sp" />

            </LinearLayout>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="TurtleGoal Logo" />

        </LinearLayout>

        <!-- ── Progress Card ───────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="#33D3C3BE"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Progress"
                    android:textColor="#6D574F"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Goals -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvGoalsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#286B33"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Goals"
                            android:textColor="#9E8880"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Tasks Done -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCompletedTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#286B33"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tasks Done"
                            android:textColor="#9E8880"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Completion % -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#286B33"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Complete"
                            android:textColor="#9E8880"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Today's Tasks Card ──────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="#33D3C3BE"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Tasks"
                    android:textColor="#6D574F"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Task items are added here programmatically -->
                <LinearLayout
                    android:id="@+id/llTasksContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Shown when there are no pending tasks -->
                <TextView
                    android:id="@+id/tvNoTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="No tasks for today 🎉"
                    android:textColor="#9E8880"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <!-- Loading indicator -->
                <TextView
                    android:id="@+id/tvTasksLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Loading…"
                    android:textColor="#9E8880"
                    android:textSize="14sp"
                    android:visibility="visible" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Action Buttons ──────────────────────────────────────────── -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateGoal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#286B33"
            android:text="＋  Create a Goal"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <!--
        TODO: CommunityActivity is planned but not yet implemented.
        Once CommunityActivity is created, un-comment this button and wire it up in MainActivity.cs.

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCommunity"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#5C7B6A"
            android:text="🌍  Community"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="12dp" />
        -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="#6D574F"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:strokeColor="#6D574F"
            app:strokeWidth="1dp" />

    </LinearLayout>

</ScrollView>
