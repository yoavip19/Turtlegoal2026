<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F6">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_roadmap"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <!-- Goal title & description header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_roadmap_goal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6D574F"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_roadmap_goal_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9E8880"
            android:textSize="14sp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/pb_roadmap_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progressTint="#286B33"
            android:progressBackgroundTint="#E0E0E0" />

        <TextView
            android:id="@+id/tv_roadmap_progress_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9E8880"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Task list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_roadmap_tasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />

    <!-- Tip input area (visible only for tippers) -->
    <LinearLayout
        android:id="@+id/ll_tip_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/et_tip_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Write a tip…"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:maxLines="3" />

        <Button
            android:id="@+id/btn_send_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Send"
            android:textColor="#FFFFFF"
            android:backgroundTint="#286B33" />

    </LinearLayout>

</LinearLayout>
